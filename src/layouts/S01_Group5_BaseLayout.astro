---
import { ViewTransitions } from 'astro:transitions';
import '../styles/S01_Group5_theme.css';

export interface Props {
  title: string;
  description?: string;
}

// .astro pages pass props directly; .mdx pages pass them via frontmatter.
const { title, description = 'Silicon Minds: The Evolution of the Mobile Microprocessor' } = Astro.props.frontmatter ?? Astro.props;
const base = import.meta.env.BASE_URL;

// Active nav detection
const path = Astro.url.pathname.replace(base.replace(/\/$/, ''), '') || '/';
const isActive = (href: string) => {
  if (href === '/silicon-minds') return path === '/silicon-minds' || path === '/silicon-minds/';
  return path.startsWith(href);
};

const navLinks = [
  { href: '/silicon-minds', label: 'Home' },
  { href: '/silicon-minds/explore', label: 'Explore' },
  { href: '/silicon-minds/timeline', label: 'Timeline' },
  { href: '/silicon-minds/about', label: 'About' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Silicon Minds</title>
  <ViewTransitions />
</head>
<body class="text-text-primary min-h-screen flex flex-col" style="background: transparent;">

  <!-- ── Skip link (keyboard a11y) ─────────────────────────── -->
  <a href="#main-content" class="skip-link">Skip to content</a>

  <!-- ── Fixed animated circuit background ─────────────────── -->
  <div
    aria-hidden="true"
    class="bg-noise"
    style="position: fixed; inset: 0; z-index: -10; pointer-events: none; background-color: var(--bg-base); overflow: hidden;"
  >
    <svg
      class="circuit-svg"
      width="100%" height="100%"
      viewBox="0 0 1200 800"
      preserveAspectRatio="xMidYMid slice"
      style="position:absolute; inset:0;"
    >
      <defs>
        <!-- Repeating circuit-trace texture -->
        <pattern id="circuit-tile" width="200" height="200" patternUnits="userSpaceOnUse">
          <g fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="1">
            <path d="M0 40 H200 M120 0 V200 M40 40 V120 H120 M160 80 H200" />
            <path d="M0 160 H80 V120 M80 200 V160" />
          </g>
          <g fill="rgba(255,255,255,0.07)">
            <circle cx="40" cy="40" r="2.5" /><circle cx="120" cy="120" r="2.5" />
            <circle cx="120" cy="40" r="1.8" /><circle cx="80" cy="160" r="1.8" />
          </g>
          <g fill="none" stroke="rgba(255,255,255,0.045)"><rect x="156" y="76" width="9" height="9" rx="1"/></g>
        </pattern>

        <radialGradient id="pulse-glow">
          <stop offset="0%" stop-color="currentColor" stop-opacity="1"/>
          <stop offset="100%" stop-color="currentColor" stop-opacity="0"/>
        </radialGradient>
      </defs>

      <rect width="1200" height="800" fill="url(#circuit-tile)" />

      {/* Always rendered; visibility is controlled by the .circuit-on class on
          <body>, which the visitor toggles with the button in the corner. */}
      <Fragment>
          <!-- Blinking junction nodes -->
          <g class="circuit-anim">
            <circle class="node n1" cx="120"  cy="40"  r="3" fill="#22D3EE"/>
            <circle class="node n2" cx="320"  cy="240" r="3" fill="#34D399"/>
            <circle class="node n3" cx="520"  cy="40"  r="3" fill="#22D3EE"/>
            <circle class="node n4" cx="720"  cy="320" r="3" fill="#A78BFA"/>
            <circle class="node n5" cx="920"  cy="120" r="3" fill="#F472B6"/>
            <circle class="node n6" cx="1080" cy="440" r="3" fill="#22D3EE"/>
            <circle class="node n1" cx="200"  cy="560" r="3" fill="#A78BFA"/>
            <circle class="node n3" cx="440"  cy="600" r="3" fill="#34D399"/>
            <circle class="node n5" cx="680"  cy="680" r="3" fill="#22D3EE"/>
            <circle class="node n2" cx="880"  cy="640" r="3" fill="#F472B6"/>
            <circle class="node n4" cx="1040" cy="720" r="3" fill="#34D399"/>
            <circle class="node n6" cx="80"   cy="320" r="3" fill="#F472B6"/>
          </g>

          <!-- Data pulses traveling along traces -->
          <g class="circuit-anim">
            <circle r="2.6" fill="#22D3EE">
              <animateMotion path="M-20 40 H1220" dur="6s" begin="0s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.05;0.9;1" dur="6s" begin="0s" repeatCount="indefinite"/>
            </circle>
            <circle r="2.6" fill="#A78BFA">
              <animateMotion path="M120 820 V-20" dur="7s" begin="1.5s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.05;0.9;1" dur="7s" begin="1.5s" repeatCount="indefinite"/>
            </circle>
            <circle r="2.6" fill="#F472B6">
              <animateMotion path="M1220 440 H-20" dur="8s" begin="0.8s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.05;0.9;1" dur="8s" begin="0.8s" repeatCount="indefinite"/>
            </circle>
            <circle r="2.6" fill="#34D399">
              <animateMotion path="M720 820 V-20" dur="6.5s" begin="3s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.05;0.9;1" dur="6.5s" begin="3s" repeatCount="indefinite"/>
            </circle>
            <circle r="2.6" fill="#22D3EE">
              <animateMotion path="M-20 600 H1220" dur="9s" begin="2.2s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.05;0.9;1" dur="9s" begin="2.2s" repeatCount="indefinite"/>
            </circle>
          </g>
      </Fragment>
    </svg>
  </div>

  <!-- ── Nav ──────────────────────────────────────────────── -->
  <header
    class="sticky top-0 z-50"
    style="background: rgba(10,10,15,0.8); backdrop-filter: blur(16px) saturate(180%); border-bottom: 1px solid rgba(255,255,255,0.06);"
  >
    <!-- Mobile toggle state. Must be a direct sibling of the mobile panel below for peer-checked to work.
         Visually hidden via CSS but keyboard-focusable, so the menu works without a mouse. -->
    <input type="checkbox" id="nav-toggle" class="peer" aria-label="Toggle navigation menu" />

    <div class="max-w-7xl mx-auto px-5 sm:px-8">
      <div class="flex items-center justify-between h-14">

        <!-- Logo -->
        <a
          href={`${base}silicon-minds`}
          class="flex items-center gap-2.5 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded-sm"
          aria-label="Silicon Minds home"
        >
          <!-- Chip icon -->
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <rect x="5" y="5" width="8" height="8" rx="1.5" stroke="#00E5FF" stroke-width="1.2"/>
            <line x1="9" y1="1" x2="9" y2="5" stroke="#00E5FF" stroke-width="1.2" stroke-linecap="round"/>
            <line x1="9" y1="13" x2="9" y2="17" stroke="#00E5FF" stroke-width="1.2" stroke-linecap="round"/>
            <line x1="1" y1="9" x2="5" y2="9" stroke="#00E5FF" stroke-width="1.2" stroke-linecap="round"/>
            <line x1="13" y1="9" x2="17" y2="9" stroke="#00E5FF" stroke-width="1.2" stroke-linecap="round"/>
            <line x1="5" y1="1" x2="5" y2="5" stroke="#00E5FF" stroke-width="1.2" stroke-linecap="round" opacity="0.45"/>
            <line x1="13" y1="1" x2="13" y2="5" stroke="#00E5FF" stroke-width="1.2" stroke-linecap="round" opacity="0.45"/>
            <line x1="5" y1="13" x2="5" y2="17" stroke="#00E5FF" stroke-width="1.2" stroke-linecap="round" opacity="0.45"/>
            <line x1="13" y1="13" x2="13" y2="17" stroke="#00E5FF" stroke-width="1.2" stroke-linecap="round" opacity="0.45"/>
          </svg>
          <span
            class="font-heading font-bold text-sm tracking-[0.22em] text-text-primary"
            style="letter-spacing: 0.22em;"
          >SILICON MINDS</span>
        </a>

        <!-- Desktop nav -->
        <nav aria-label="Main navigation" class="hidden md:flex items-center gap-1">
          {navLinks.map(link => (
            <a
              href={`${base}${link.href.replace(/^\//, '')}`}
              class={`relative px-3 py-1.5 text-sm rounded-md transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary ${
                isActive(link.href)
                  ? 'text-text-primary'
                  : 'text-text-secondary hover:text-text-primary'
              }`}
            >
              {link.label}
              {isActive(link.href) && (
                <span
                  class="absolute bottom-0 left-3 right-3 h-px rounded-full"
                  style="background: var(--color-primary); opacity: 0.7;"
                  aria-hidden="true"
                />
              )}
            </a>
          ))}
          <a
            href={`${base}silicon-minds/explore`}
            class="btn-primary ml-3 py-2 px-4 text-xs"
            style="padding: 7px 16px; font-size: 14px; letter-spacing: 0.05em;"
          >
            Enter Exhibit
          </a>
        </nav>

        <!-- Mobile hamburger (toggles #nav-toggle at the top of <header>) -->
        <label
          for="nav-toggle"
          class="md:hidden flex flex-col justify-center gap-[5px] w-9 h-9 cursor-pointer p-1.5 rounded focus-visible:ring-2 focus-visible:ring-primary"
          aria-label="Toggle navigation"
        >
          <span class="hamburger-line block h-px bg-text-secondary" style="width: 18px;"></span>
          <span class="hamburger-line block h-px bg-text-secondary" style="width: 14px;"></span>
          <span class="hamburger-line block h-px bg-text-secondary" style="width: 18px;"></span>
        </label>
      </div>
    </div>

    <!-- Mobile nav panel -->
    <div
      class="hidden peer-checked:block md:hidden"
      style="border-top: 1px solid rgba(255,255,255,0.06); background: rgba(10,10,15,0.97);"
    >
      <nav aria-label="Mobile navigation" class="flex flex-col px-5 py-4 gap-1">
        {navLinks.map(link => (
          <a
            href={`${base}${link.href.replace(/^\//, '')}`}
            class={`px-3 py-2.5 text-sm rounded-md transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary ${
              isActive(link.href)
                ? 'text-text-primary bg-white/[0.04]'
                : 'text-text-secondary hover:text-text-primary'
            }`}
          >
            {link.label}
          </a>
        ))}
        <a href={`${base}silicon-minds/explore`} class="btn-primary text-sm text-center mt-3 justify-center">
          Enter Exhibit
        </a>
      </nav>
    </div>

    <!-- Reading progress -->
    <div id="scroll-progress" aria-hidden="true"></div>
  </header>

  <!-- ── Main ──────────────────────────────────────────────── -->
  <main id="main-content" tabindex="-1" class="flex-1" style="view-transition-name: main-content; outline: none;">
    <slot />
  </main>

  <!-- ── Footer ────────────────────────────────────────────── -->
  <footer style="border-top: 1px solid rgba(255,255,255,0.06); background: var(--color-surface); margin-top: 80px;">
    <div class="max-w-7xl mx-auto px-5 sm:px-8 py-10">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-2.5">
          <svg width="14" height="14" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <rect x="5" y="5" width="8" height="8" rx="1.5" stroke="#00E5FF" stroke-width="1.2" opacity="0.6"/>
            <line x1="9" y1="1" x2="9" y2="5" stroke="#00E5FF" stroke-width="1.2" stroke-linecap="round" opacity="0.6"/>
            <line x1="9" y1="13" x2="9" y2="17" stroke="#00E5FF" stroke-width="1.2" stroke-linecap="round" opacity="0.6"/>
            <line x1="1" y1="9" x2="5" y2="9" stroke="#00E5FF" stroke-width="1.2" stroke-linecap="round" opacity="0.6"/>
            <line x1="13" y1="9" x2="17" y2="9" stroke="#00E5FF" stroke-width="1.2" stroke-linecap="round" opacity="0.6"/>
          </svg>
          <span class="font-heading font-bold text-xs tracking-[0.2em] text-text-secondary">SILICON MINDS</span>
        </div>
        <p class="text-text-secondary text-xs text-center">
          DLSU CSARCH2 &mdash; Computer Organization & Architecture 2 &mdash; A.Y. 2025–2026
        </p>
        <p class="font-mono text-xs text-text-secondary">&copy; {new Date().getFullYear()}</p>
      </div>
    </div>
  </footer>

  <!-- ── Circuit animation toggle ──────────────────────────── -->
  <button
    id="circuit-toggle"
    type="button"
    aria-pressed="false"
    aria-label="Turn on circuit background animation"
    title="Circuit animation"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="2.5" />
      <path d="M12 2v5M12 17v5M2 12h5M17 12h5" />
      <path d="M5 5l3 3M19 5l-3 3M5 19l3-3M19 19l-3-3" opacity="0.55" />
    </svg>
    <span id="circuit-toggle-label">Lights off</span>
  </button>

  <!-- ── Back to top ───────────────────────────────────────── -->
  <button id="back-to-top" aria-label="Back to top">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 19V5M5 12l7-7 7 7"/>
    </svg>
  </button>

  <!-- ── Circuit animation toggle: off by default, remembered ─ -->
  <script>
    function applyCircuit(on: boolean) {
      document.body.classList.toggle('circuit-on', on);
      const btn = document.getElementById('circuit-toggle');
      const label = document.getElementById('circuit-toggle-label');
      if (btn) {
        btn.setAttribute('aria-pressed', String(on));
        btn.setAttribute('aria-label', on
          ? 'Turn off circuit background animation'
          : 'Turn on circuit background animation');
      }
      if (label) label.textContent = on ? 'Lights on' : 'Lights off';
    }

    function initCircuitToggle() {
      // Default off. Only a previously saved "on" turns it on.
      applyCircuit(localStorage.getItem('sm-circuit') === 'on');
    }

    document.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement).closest?.('#circuit-toggle')) return;
      const next = !document.body.classList.contains('circuit-on');
      localStorage.setItem('sm-circuit', next ? 'on' : 'off');
      applyCircuit(next);
    });

    initCircuitToggle();
    document.addEventListener('astro:page-load', initCircuitToggle);
  </script>

  <!-- ── Scroll UI: progress bar + back-to-top ─────────────── -->
  <script>
    let scrollTicking = false;
    function updateScrollUI() {
      scrollTicking = false;
      const bar = document.getElementById('scroll-progress');
      const btn = document.getElementById('back-to-top');
      const max = document.documentElement.scrollHeight - window.innerHeight;
      if (bar) bar.style.width = (max > 0 ? Math.min((window.scrollY / max) * 100, 100) : 0) + '%';
      if (btn) btn.classList.toggle('show', window.scrollY > 600);
    }
    window.addEventListener('scroll', () => {
      if (!scrollTicking) { scrollTicking = true; requestAnimationFrame(updateScrollUI); }
    }, { passive: true });
    // delegate click so the handler survives view-transition DOM swaps
    document.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest?.('#back-to-top')) {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        window.scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' });
      }
    });
    document.addEventListener('astro:page-load', updateScrollUI);
    updateScrollUI();
  </script>

  <!-- ── Scroll reveal script ───────────────────────────────── -->
  <script>
    function initReveal() {
      const items = document.querySelectorAll('.reveal');
      if (!items.length) return;
      const vh = window.innerHeight || document.documentElement.clientHeight;
      const obs = new IntersectionObserver(
        (entries) => entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } }),
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      items.forEach(el => {
        // Anything already within the viewport on load reveals immediately (no blank first paint)
        if (el.getBoundingClientRect().top < vh * 0.9) {
          el.classList.add('visible');
        } else {
          obs.observe(el);
        }
      });
    }
    initReveal();
    document.addEventListener('astro:page-load', initReveal);
  </script>

  <!-- ── Stats count-up script ─────────────────────────────── -->
  <script>
    function initCountUp() {
      const els = document.querySelectorAll('[data-count-to]');
      if (!els.length) return;
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (!e.isIntersecting) return;
          const el = e.target as HTMLElement;
          const target = parseInt(el.dataset.countTo || '0');
          const suffix = el.dataset.countSuffix || '';
          const dur = 1400;
          const start = performance.now();
          const tick = (now: number) => {
            const t = Math.min((now - start) / dur, 1);
            const ease = 1 - Math.pow(1 - t, 3);
            el.textContent = Math.round(ease * target) + suffix;
            if (t < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
          obs.unobserve(el);
        });
      }, { threshold: 0.5 });
      els.forEach(el => obs.observe(el));
    }
    initCountUp();
    document.addEventListener('astro:page-load', initCountUp);
  </script>

  <!-- ── Scroll to #hash target (fixes cross-page anchor links like Start Quiz) ─ -->
  <script>
    function scrollToHash() {
      if (!location.hash) return;
      const el = document.getElementById(decodeURIComponent(location.hash.slice(1)));
      if (!el) return;
      // reveal it if it's a scroll-reveal target that hasn't animated in yet
      el.classList.add('visible');
      // wait a frame so layout is settled, then jump to it
      requestAnimationFrame(() => requestAnimationFrame(() => {
        el.scrollIntoView({ block: 'start' });
      }));
    }
    scrollToHash();
    document.addEventListener('astro:page-load', scrollToHash);
  </script>

</body>
</html>
